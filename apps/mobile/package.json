{
  "name": "@quenchr/mobile",
  "version": "0.1.0",
  "main": "index.ts",
  "scripts": {
    "dev": "expo start --dev-client",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build": "expo export",
    "build:dev:android": "eas build --profile development --platform android",
    "build:dev:ios": "eas build --profile development --platform ios",
    "build:preview": "eas build --profile preview --platform all",
    "build:production": "eas build --profile production --platform all",
    "lint": "tsc --noEmit",
    "clean": "rm -rf .expo dist node_modules"
  },
  "dependencies": {
    "expo": "~55.0.6",
    "expo-router": "~5.0.7",
    "expo-linking": "~55.0.7",
    "expo-constants": "~17.1.6",
    "expo-status-bar": "~55.0.4",
    "expo-image-picker": "~16.1.4",
    "expo-sharing": "~13.1.3",
    "expo-notifications": "~0.31.1",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-safe-area-context": "~5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-reanimated": "~3.17.4",
    "react-native-gesture-handler": "~2.27.1",
    "react-native-svg": "~15.11.2",
    "@supabase/supabase-js": "^2.49.0",
    "zustand": "^5.0.0",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@quenchr/shared": "workspace:*",
    "@quenchr/supabase-client": "workspace:*",
    "expo-gl": "~55.0.9",
    "expo-image-manipulator": "~13.1.7",
    "expo-file-system": "~55.0.10",
    "@tensorflow/tfjs": "^4.22.0",
    "@tensorflow/tfjs-react-native": "^1.0.0",
    "nsfwjs": "^4.1.0",
    "react-native-view-shot": "^4.0.2",
    "expo-dev-client": "~55.0.16",
    "expo-video-thumbnails": "~9.1.3",
    "react-native-nitro-modules": "^0.31.0",
    "react-native-nitro-screen-recorder": "^0.4.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~5.9.2"
  },
  "private": true
}
